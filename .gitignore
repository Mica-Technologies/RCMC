# the repo's history. Matches docs/agent_progress/ in the sibling Mica mods.
docs/AGENT-PLANS/

# Local reference: cloned/decompiled third-party mod source for analysis only.
# Never committed (license + repo-hygiene reasons). Immersive Railroading and
# UniversalModCore are the ones worth reading; keep them out here.
example-source/

